generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String?
  name          String
  phone         String?
  role          Role           @default(CLIENT)
  avatar        String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  Booking       Booking[]
  ClientProfile ClientProfile?
  Inquiry       Inquiry[]
  Payment       Payment[]
  Review        Review[]
  sessions      Session[]
  specialist    Specialist?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Specialist {
  id                    String               @id @default(cuid())
  userId                String               @unique
  businessName          String?
  description           String
  experienceYears       Int?
  city                  String
  serviceAreas          String[]
  address               String?
  latitude              Float?
  longitude             Float?
  verified              Boolean              @default(false)
  verifiedAt            DateTime?
  isFeatured            Boolean              @default(false)
  featuredExpiresAt     DateTime?
  subscriptionPlan      SubscriptionPlan     @default(FREE)
  subscriptionExpiresAt DateTime?
  rating                Float                @default(0)
  reviewCount           Int                  @default(0)
  viewsCount            Int                  @default(0)
  inquiryCount          Int                  @default(0)
  completedJobs         Int                  @default(0)
  workingHours          Json?
  website               String?
  facebook              String?
  instagram             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  badgeType             BadgeType?
  creditPrice           Float                @default(2.99)
  credits               Int                  @default(0)
  maxImages             Int                  @default(5)
  maxPriceListItems     Int                  @default(0)
  monthlyCredits        Int                  @default(0)
  phone                 String?
  priorityInquiries     Boolean              @default(false)
  totalCreditsUsed      Int                  @default(0)
  verificationBadge     Boolean              @default(false)
  verificationDocs      String[]
  verificationExpiry    DateTime?
  verifiedBy            String?
  Booking               Booking[]
  CategorySuggestion    CategorySuggestion[]
  Certification         Certification[]
  CreditTransaction     CreditTransaction[]
  favorites             Favorite[]
  GalleryImage          GalleryImage[]
  inquiries             Inquiry[]
  InquiryResponse       InquiryResponse[]
  Payment               Payment[]
  PriceListItem         PriceListItem[]
  reviews               Review[]
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  SpecialistCategory    SpecialistCategory[]
}

model Inquiry {
  id              String            @id @default(cuid())
  specialistId    String?
  clientId        String?
  message         String
  phone           String?
  email           String
  status          InquiryStatus     @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  categoryId      Int
  city            String
  name            String
  reviewId        String?
  completedAt     DateTime?
  notes           String?
  repliedAt       DateTime?
  respondedBy     Int               @default(0)
  viewedAt        DateTime?
  viewedBy        Int               @default(0)
  Booking         Booking?
  Category        Category          @relation(fields: [categoryId], references: [id])
  User            User?             @relation(fields: [clientId], references: [id])
  Review          Review?           @relation(fields: [reviewId], references: [id])
  specialist      Specialist?       @relation(fields: [specialistId], references: [id])
  InquiryResponse InquiryResponse[]
}

model Review {
  id           String     @id @default(cuid())
  specialistId String
  clientId     String
  rating       Int
  comment      String?
  createdAt    DateTime   @default(now())
  isPublic     Boolean    @default(true)
  isVerified   Boolean    @default(false)
  response     String?
  responseAt   DateTime?
  updatedAt    DateTime   @updatedAt
  Booking      Booking[]
  Inquiry      Inquiry[]
  User         User       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model Favorite {
  clientId      String
  specialistId  String
  createdAt     DateTime      @default(now())
  ClientProfile ClientProfile @relation(fields: [clientId], references: [userId], onDelete: Cascade)
  specialist    Specialist    @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@id([clientId, specialistId])
}

model CategorySuggestion {
  id           String                   @id @default(cuid())
  specialistId String?
  name         String
  description  String
  reason       String?
  status       CategorySuggestionStatus @default(PENDING)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime
  adminNotes   String?
  parentId     Int?
  parentName   String?
  type         String?
  Specialist   Specialist               @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model Banner {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?
  position    BannerPosition
  categoryId  Int?
  city        String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  clicks      Int            @default(0)
  createdBy   String?
  endDate     DateTime?
  impressions Int            @default(0)
  startDate   DateTime?
  updatedAt   DateTime
  Category    Category?      @relation(fields: [categoryId], references: [id])
}

model Booking {
  id            String        @id
  inquiryId     String        @unique
  specialistId  String
  clientId      String
  status        BookingStatus @default(PENDING)
  price         Float?
  scheduledDate DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  reviewId      String?
  User          User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  Inquiry       Inquiry       @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  Review        Review?       @relation(fields: [reviewId], references: [id])
  Specialist    Specialist    @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model Category {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique
  slug               String               @unique
  description        String?
  icon               String?
  sortOrder          Int                  @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  Banner             Banner[]
  Inquiry            Inquiry[]
  PriceListItem      PriceListItem[]
  SpecialistCategory SpecialistCategory[]
  Subcategory        Subcategory[]
}

model Certification {
  id             Int        @id @default(autoincrement())
  specialistId   String
  name           String
  issuer         String?
  issueDate      DateTime?
  expiryDate     DateTime?
  certificateUrl String?
  verified       Boolean    @default(false)
  Specialist     Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id          String     @id
  userId      String     @unique
  address     String?
  city        String?
  preferences Json?
  User        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Favorite    Favorite[]
}

model CreditTransaction {
  id           String          @id
  specialistId String
  amount       Int
  type         TransactionType
  createdAt    DateTime        @default(now())
  description  String?
  expiresAt    DateTime?
  price        Float?
  Specialist   Specialist      @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id           Int        @id @default(autoincrement())
  specialistId String
  imageUrl     String
  thumbnailUrl String?
  title        String?
  description  String?
  sortOrder    Int        @default(0)
  isPrimary    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  Specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model InquiryResponse {
  id           String     @id
  inquiryId    String
  specialistId String
  message      String
  createdAt    DateTime   @default(now())
  creditsSpent Int        @default(1)
  viewed       Boolean    @default(false)
  Inquiry      Inquiry    @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  Specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@unique([inquiryId, specialistId])
}

model Payment {
  id           String        @id
  userId       String
  specialistId String
  amount       Float
  status       PaymentStatus @default(PENDING)
  type         PaymentType
  createdAt    DateTime      @default(now())
  credits      Int?
  expiresAt    DateTime?
  updatedAt    DateTime
  Specialist   Specialist    @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  User         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PriceListItem {
  id           Int        @id @default(autoincrement())
  specialistId String
  name         String
  description  String?
  price        Float?
  unit         String?
  categoryId   Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  isNegotiable Boolean    @default(false)
  maxPrice     Float?
  minPrice     Float?
  Category     Category?  @relation(fields: [categoryId], references: [id])
  Specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model ServiceSuggestion {
  id          String   @id
  locale      String   @default("bg")
  name        String
  category    String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model SpecialistCategory {
  id            Int          @id @default(autoincrement())
  specialistId  String
  categoryId    Int
  subcategoryId Int?
  price         Float?
  experience    String?
  Category      Category     @relation(fields: [categoryId], references: [id])
  Specialist    Specialist   @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  Subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])

  @@unique([specialistId, categoryId, subcategoryId])
}

model Subcategory {
  id                 Int                  @id @default(autoincrement())
  categoryId         Int
  name               String
  slug               String
  description        String?
  sortOrder          Int                  @default(0)
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  SpecialistCategory SpecialistCategory[]
  Category           Category             @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, slug])
}

enum BadgeType {
  BASIC
  PROFESSIONAL
  PREMIUM
}

enum BannerPosition {
  HOME_LEFT
  HOME_RIGHT
  CATEGORY_TOP
  CATEGORY_SIDEBAR
  SEARCH_SIDEBAR
  SPECIALIST_SIDEBAR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum CategorySuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InquiryStatus {
  PENDING
  VIEWED
  REPLIED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  EXPIRED
}

enum PaymentType {
  CREDIT_PURCHASE
  INQUIRY_ACCESS
  SUBSCRIPTION
}

enum Role {
  CLIENT
  SPECIALIST
  ADMIN
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum TransactionType {
  PURCHASE
  USAGE
  MONTHLY_RESET
  BONUS
  REFUND
}
