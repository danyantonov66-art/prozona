import Image from "next/image"
import { prisma } from "@/lib/prisma"
import { notFound } from "next/navigation"

interface Props {
  params: Promise<{
    id: string
    locale: string
  }>
}

export default async function SpecialistPage({ params }: Props) {
  const { id, locale } = await params

  const specialist = await prisma.specialist.findUnique({
    where: { id },
    include: {
      user: true,
      SpecialistCategory: {
        include: {
          Category: true,
        },
      },
      GalleryImage: {
        orderBy: {
          isPrimary: "desc",
        },
        take: 1,
      },
    },
  })

  if (!specialist) return notFound()

  const profileImage =
    specialist.user?.image ||
    specialist.user?.avatar ||
    specialist.GalleryImage?.[0]?.imageUrl ||
    null

  const schema = {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: specialist.businessName || specialist.user?.name || "Специалист",
    description: specialist.description || "",
    url: `https://prozona.bg/${locale}/specialists/${specialist.id}`,
    telephone: specialist.phone || specialist.user?.phone || "",
    address: {
      "@type": "PostalAddress",
      addressLocality: specialist.city || "",
      addressCountry: "BG",
    },
    areaServed: {
      "@type": "City",
      name: specialist.city || "",
    },
    image: profileImage || undefined,
    serviceType:
      specialist.SpecialistCategory?.map((item) => item.Category?.name).filter(Boolean) || [],
    provider: {
      "@type": "Person",
      name: specialist.user?.name || specialist.businessName || "Специалист",
    },
  }

  return (
    <main className="mx-auto max-w-5xl px-4 py-10 text-white">
      <script
        type="application/ld+json"
        dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }}
      />

      <div className="mb-8 flex flex-col gap-6 md:flex-row md:items-start">
        <div className="shrink-0">
          {profileImage ? (
            <Image
              src={profileImage}
              alt={specialist.businessName || specialist.user?.name || "Специалист"}
              width={160}
              height={160}
              className="h-40 w-40 rounded-2xl object-cover border border-white/10"
              unoptimized
            />
          ) : (
            <div className="flex h-40 w-40 items-center justify-center rounded-2xl border border-white/10 bg-[#1A1A2E] text-4xl font-bold text-[#1DB954]">
              {(specialist.businessName || specialist.user?.name || "С")
                .charAt(0)
                .toUpperCase()}
            </div>
          )}
        </div>

        <div className="flex-1">
          <h1 className="mb-4 text-3xl font-bold">
            {specialist.businessName || specialist.user?.name}
          </h1>

          <p className="mb-6 text-gray-300">
            {specialist.description || "Няма добавено описание."}
          </p>

          <div className="space-y-2 text-gray-400">
            {specialist.city && <p>Град: {specialist.city}</p>}
            {(specialist.phone || specialist.user?.phone) && (
              <p>Телефон: {specialist.phone || specialist.user?.phone}</p>
            )}
            {specialist.user?.name && <p>Име: {specialist.user.name}</p>}
          </div>
        </div>
      </div>

      {specialist.SpecialistCategory?.length > 0 && (
        <div className="mt-6">
          <h2 className="mb-2 text-xl font-semibold">Услуги</h2>

          <ul className="ml-5 list-disc space-y-1 text-gray-300">
            {specialist.SpecialistCategory.map((item) => (
              <li key={item.id}>{item.Category?.name}</li>
            ))}
          </ul>
        </div>
      )}
    </main>
  )
}